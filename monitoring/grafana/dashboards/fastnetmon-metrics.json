{
  "uid": "fastnetmon-metrics",
  "title": "FastNetMon Metrics",
  "tags": [
    "fastnetmon",
    "ddos",
    "monitoring"
  ],
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Packets Processed",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(fastnetmon_total_simple_packets_processed[1m]))",
          "legendFormat": "simple packets/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(fastnetmon_total_ipv4_packets[1m]))",
          "legendFormat": "ipv4 packets/sec",
          "refId": "B"
        },
        {
          "expr": "sum(rate(fastnetmon_total_ipv6_packets[1m]))",
          "legendFormat": "ipv6 packets/sec",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Traffic Bits",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(fastnetmon_total_traffic_bits[1m]))",
          "legendFormat": "traffic bits/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Estimated PPS",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(fastnetmon_total_simple_packets_processed[1m]))",
          "legendFormat": "estimated pps",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "FastNetMon Total Hosts",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "max(fastnetmon_total_number_of_hosts)",
          "legendFormat": "hosts",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Write Errors",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(rate(fastnetmon_influxdb_writes_failed[1m]))",
          "legendFormat": "writes failed/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(fastnetmon_influxdb_writes_total[1m]))",
          "legendFormat": "writes total/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Speed Recalculation Time",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "avg(fastnetmon_speed_recalculation_time_microseconds)",
          "legendFormat": "microseconds",
          "refId": "A"
        },
        {
          "expr": "avg(fastnetmon_speed_recalculation_time_seconds)",
          "legendFormat": "seconds",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Traffic Early Warning",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum(rate(fastnetmon_total_traffic_bits[1m]))",
          "legendFormat": "traffic bits/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100000000000
              },
              {
                "color": "orange",
                "value": 500000000000
              },
              {
                "color": "red",
                "value": 1000000000000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Peak Traffic (5m)",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "targets": [
        {
          "expr": "max_over_time(sum(rate(fastnetmon_total_traffic_bits[1m]))[5m:])",
          "legendFormat": "peak traffic bits/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100000000000
              },
              {
                "color": "orange",
                "value": 500000000000
              },
              {
                "color": "red",
                "value": 1000000000000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    }
  ]
}